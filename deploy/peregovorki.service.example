[Unit]
Description=Peregovorki Flask App
After=network.target

[Service]
User=www-data
Group=www-data
WorkingDirectory=/var/www/peregovorki
EnvironmentFile=/var/www/peregovorki/.env
ExecStart=/var/www/peregovorki/venv/bin/gunicorn -w 3 -b 127.0.0.1:8000 wsgi:app
Restart=always

[Install]
WantedBy=multi-user.target
